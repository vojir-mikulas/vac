# Copy to .env and fill in real values. .env is gitignored.

# 32-byte hex (64 chars). Generate with: openssl rand -hex 32
VAC_MASTER_KEY=

# Database password used by both vac-db (POSTGRES_PASSWORD) and vac-api's
# VAC_DATABASE_URL. Generate with: openssl rand -base64 24
VAC_DB_PASSWORD=

# GID granted to the non-root vac user inside the container so it can read
# /var/run/docker.sock.
#   Linux:           DOCKER_GID=$(getent group docker | cut -d: -f3)
#   Docker Desktop:  DOCKER_GID=0   (the bind-mounted socket is owned by
#                                    root:root inside the Docker Desktop VM)
# DOCKER_GID=

# VAC's own domain. When set, the dashboard moves to https://vac.<domain>
# (Let's Encrypt cert via vac-proxy / Caddy) and each app gets an automatic
# {app}.{domain} subdomain over HTTPS. Requires both A vac.<domain> and a
# wildcard A *.<domain> pointing at this host, plus ports 80/443 reachable.
# http://<host>:9393 keeps working as a recovery fallback.
# Leave empty to keep the dashboard on plain HTTP (a banner in the UI will
# warn about it).
# VAC_BASE_DOMAIN=example.com

# Override the dashboard hostname when VAC_BASE_DOMAIN is set. Defaults to
# vac.<VAC_BASE_DOMAIN>; set to the apex (example.com) or any other host you
# own to pin a different name. Ignored when VAC_BASE_DOMAIN is empty.
# VAC_CONTROL_DOMAIN=admin.example.com

# Host port for the vac-api dashboard (defaults to 9393). Note: vac-proxy binds
# 80/443 on the host for app ingress.
# VAC_HOST_PORT=9393

# Host port for managed Postgres (vac-db), bound on 127.0.0.1 only for operator
# debugging. Deliberately NOT 5432 so it can't collide with a user app that
# publishes its own Postgres on the standard port. The container still listens
# on 5432 internally; apps reach it over vac-edge, not the host.
# VAC_DB_HOST_PORT=9432

# Notifications (Phase 4). Webhook URLs for Discord / Slack. These env vars
# override anything configured in the dashboard. Leave empty to manage them in
# Settings → Notifications instead (stored encrypted with VAC_MASTER_KEY).
# VAC_NOTIFY_DISCORD_URL=
# VAC_NOTIFY_SLACK_URL=

# Real-time tuning (Phase 4). Defaults shown.
# VAC_STATS_POLL_INTERVAL=2s     # per-service docker stats poll cadence
# VAC_LOG_RING_BUFFER=10000      # runtime log lines kept per service
