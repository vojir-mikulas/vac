# Copy to .env and fill in real values. .env is gitignored.

# 32-byte hex (64 chars). Generate with: openssl rand -hex 32
VAC_MASTER_KEY=

# Database password used by both vac-db (POSTGRES_PASSWORD) and vac-api's
# VAC_DATABASE_URL. Generate with: openssl rand -base64 24
VAC_DB_PASSWORD=

# GID granted to the non-root vac user inside the container so it can read
# /var/run/docker.sock.
#   Linux:           DOCKER_GID=$(getent group docker | cut -d: -f3)
#   Docker Desktop:  DOCKER_GID=0   (the bind-mounted socket is owned by
#                                    root:root inside the Docker Desktop VM)
# DOCKER_GID=

# VAC's own domain. When set, each app gets an automatic {app}.{domain}
# subdomain over HTTPS via the vac-proxy (Caddy) reverse proxy. Requires a
# wildcard DNS record (*.<domain> → this host) and ports 80/443 reachable.
# Leave empty to disable automatic subdomains (custom domains still work).
# VAC_BASE_DOMAIN=vac.example.com

# Host port for the vac-api dashboard (defaults to 3000). Note: vac-proxy binds
# 80/443 on the host for app ingress.
# VAC_HOST_PORT=3000
